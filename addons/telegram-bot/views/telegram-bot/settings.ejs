<%- include('../../../../views/partials/head', { title: 'Telegram Settings' }) %>

<div class="card" style="max-width: 700px; margin: 2rem auto;">
  <h2>Telegram Notifications</h2>
  <p class="text-muted" style="margin-bottom: 1rem;">Send session notifications to a Telegram chat or group.</p>

  <div style="margin-bottom: 1rem; padding: 1rem; background: rgba(0, 136, 204, 0.08); border: 1px solid rgba(0, 136, 204, 0.3); border-radius: var(--radius);">
    <h3 style="color: #0088cc; margin-bottom: 0.5rem; font-size: 1rem;">Setup Guide</h3>
    <ol style="margin: 0; padding-left: 1.25rem; font-size: 0.88rem; color: var(--text-secondary); line-height: 1.7;">
      <li>Message <strong>@BotFather</strong> on Telegram &rarr; <code>/newbot</code></li>
      <li>Follow the prompts to create your bot &rarr; <strong>copy the token</strong></li>
      <li>Add the bot to your group or channel</li>
      <li>Send a message in the group, then visit:<br>
        <code>https://api.telegram.org/bot{TOKEN}/getUpdates</code><br>
        to find the <strong>chat_id</strong></li>
    </ol>
  </div>

  <form action="/telegram-bot/settings" method="POST">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <div class="form-group">
      <label>
        <input type="checkbox" name="enabled" value="1" <%= settings.enabled ? 'checked' : '' %>>
        Enable notifications
      </label>
    </div>

    <div class="form-group">
      <label for="bot_token">Bot Token</label>
      <input type="text" name="bot_token" id="bot_token" class="form-input"
        placeholder="123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11"
        value="<%= settings.bot_token ? settings.bot_token.slice(0,4) + '****' + settings.bot_token.slice(-4) : '' %>">
    </div>

    <div class="form-group">
      <label for="chat_id">Chat ID</label>
      <input type="text" name="chat_id" id="chat_id" class="form-input"
        placeholder="-1001234567890"
        value="<%= settings.chat_id || '' %>">
      <small class="form-hint">Group chat IDs start with <code>-100</code></small>
    </div>

    <div class="form-group">
      <label for="public_url">Public URL <small>(optional)</small></label>
      <input type="text" name="public_url" id="public_url" class="form-input"
        placeholder="https://quest.example.com"
        value="<%= settings.public_url || '' %>">
      <small class="form-hint">Used to build clickable links in messages</small>
    </div>

    <div style="display: flex; gap: 0.75rem; margin-top: 1rem;">
      <button type="submit" class="btn btn-primary">Save</button>
      <button type="button" class="btn btn-outline" onclick="testTelegram()">Test Connection</button>
    </div>
  </form>

  <div id="test-result" class="comms-test-result" style="margin-top: 0.75rem;"></div>
</div>

<script>
function testTelegram() {
  var resultDiv = document.getElementById('test-result');
  resultDiv.textContent = 'Sending test message...';
  resultDiv.className = 'comms-test-result';

  fetch('/telegram-bot/test', { method: 'POST', headers: { 'Content-Type': 'application/json' } })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.success) {
        resultDiv.textContent = 'Test message sent successfully!';
        resultDiv.className = 'comms-test-result comms-test-success';
      } else {
        resultDiv.textContent = 'Failed: ' + (data.error || 'Unknown error');
        resultDiv.className = 'comms-test-result comms-test-error';
      }
    })
    .catch(function() {
      resultDiv.textContent = 'Connection test failed.';
      resultDiv.className = 'comms-test-result comms-test-error';
    });
}
</script>

<%- include('../../../../views/partials/foot') %>
