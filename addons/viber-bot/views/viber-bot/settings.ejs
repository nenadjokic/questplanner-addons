<%- include('../../../../views/partials/head', { title: 'Viber Settings' }) %>

<div class="card" style="max-width: 700px; margin: 2rem auto;">
  <h2>Viber Notifications</h2>
  <p class="text-muted" style="margin-bottom: 1rem;">Send session notifications to Viber.</p>

  <div style="margin-bottom: 1rem; padding: 1rem; background: rgba(121, 92, 174, 0.08); border: 1px solid rgba(121, 92, 174, 0.3); border-radius: var(--radius);">
    <h3 style="color: #795CAE; margin-bottom: 0.5rem; font-size: 1rem;">Setup Guide</h3>
    <ol style="margin: 0; padding-left: 1.25rem; font-size: 0.88rem; color: var(--text-secondary); line-height: 1.7;">
      <li>Create a bot at <strong>partners.viber.com</strong> &rarr; copy the <strong>Auth Token</strong></li>
      <li>Subscribe to your bot from Viber</li>
      <li>Use the Viber API to find your <strong>subscriber/admin ID</strong></li>
      <li>Set the <strong>Public URL</strong> below for webhook registration and message links</li>
    </ol>
  </div>

  <form action="/viber-bot/settings" method="POST">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <div class="form-group">
      <label>
        <input type="checkbox" name="enabled" value="1" <%= settings.enabled ? 'checked' : '' %>>
        Enable notifications
      </label>
    </div>

    <div class="form-group">
      <label for="auth_token">Auth Token</label>
      <input type="text" name="auth_token" id="auth_token" class="form-input"
        placeholder="Viber bot auth token"
        value="<%= settings.auth_token ? settings.auth_token.slice(0,4) + '****' + settings.auth_token.slice(-4) : '' %>">
    </div>

    <div class="form-group">
      <label for="admin_id">Admin / Subscriber ID</label>
      <input type="text" name="admin_id" id="admin_id" class="form-input"
        placeholder="Your Viber subscriber ID"
        value="<%= settings.admin_id || '' %>">
    </div>

    <div class="form-group">
      <label for="public_url">Public URL</label>
      <input type="text" name="public_url" id="public_url" class="form-input"
        placeholder="https://quest.example.com"
        value="<%= settings.public_url || '' %>">
      <small class="form-hint">Required for Viber webhook and message links</small>
    </div>

    <div style="display: flex; gap: 0.75rem; margin-top: 1rem;">
      <button type="submit" class="btn btn-primary">Save</button>
      <button type="button" class="btn btn-outline" onclick="testViber()">Test Connection</button>
    </div>
  </form>

  <div id="test-result" class="comms-test-result" style="margin-top: 0.75rem;"></div>
</div>

<script>
function testViber() {
  var resultDiv = document.getElementById('test-result');
  resultDiv.textContent = 'Sending test message...';
  resultDiv.className = 'comms-test-result';

  fetch('/viber-bot/test', { method: 'POST', headers: { 'Content-Type': 'application/json' } })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.success) {
        resultDiv.textContent = 'Test message sent successfully!';
        resultDiv.className = 'comms-test-result comms-test-success';
      } else {
        resultDiv.textContent = 'Failed: ' + (data.error || 'Unknown error');
        resultDiv.className = 'comms-test-result comms-test-error';
      }
    })
    .catch(function() {
      resultDiv.textContent = 'Connection test failed.';
      resultDiv.className = 'comms-test-result comms-test-error';
    });
}
</script>

<%- include('../../../../views/partials/foot') %>
